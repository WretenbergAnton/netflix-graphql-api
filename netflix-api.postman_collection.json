    {
      "name": "Movies",
      "item": [
        {
          "name": "Get All Movies",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "{\n  movies(limit: 5, offset: 0) {\n    id\n    title\n    description\n    releaseYear\n    rating\n    actors {\n      name\n    }\n    genres {\n      name\n    }\n  }\n}"
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function() {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "",
                  "pm.test(\"Response has data field\", function() {",
                  "  var jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('data');",
                  "});",
                  "",
                  "pm.test(\"Movies array exists\", function() {",
                  "  var jsonData = pm.response.json();",
                  "  pm.expect(jsonData.data).to.have.property('movies');",
                  "  pm.expect(jsonData.data.movies).to.be.an('array');",
                  "  if(jsonData.data.movies.length > 0) {",
                  "    pm.environment.set('movie_id', jsonData.data.movies[0].id);",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
