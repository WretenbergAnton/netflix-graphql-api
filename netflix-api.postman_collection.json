{
  "info": {
    "name": "Netflix GraphQL API",
    "description": "Complete test collection for Netflix GraphQL API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User - Success",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation {\n  registerUser(\n    email: \"test{{$timestamp}}@example.com\"\n    password: \"password123\"\n    name: \"Test User\"\n  ) {\n    token\n    user {\n      id\n      email\n      name\n    }\n  }\n}"
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code is 200\", function() {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "",
                  "pm.test(\"Response has data field\", function() {",
                  "  var jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('data');",
                  "});",
                  "",
                  "pm.test(\"Response has token\", function() {",
                  "  var jsonData = pm.response.json();",
                  "  pm.expect(jsonData.data.registerUser.token).to.exist;",
                  "  pm.environment.set('auth_token', jsonData.data.registerUser.token);",
                  "  pm.environment.set('test_email', jsonData.data.registerUser.user.email);",
                  "});",
                  "",
                  "pm.test(\"User email matches input\", function() {",
                  "  var jsonData = pm.response.json();",
                  "  pm.expect(jsonData.data.registerUser.user.email).to.include('@example.com');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Register User - Duplicate Email",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation {\n  registerUser(\n    email: \"{{test_email}}\"\n    password: \"password123\"\n    name: \"Duplicate\"\n  ) {\n    token\n    user {\n      id\n      email\n      name\n    }\n  }\n}"
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Response has errors field\", function() {",
                  "  var jsonData = pm.response.json();",
                  "  pm.expect(jsonData).to.have.property('errors');",
                  "});",
                  "",
                  "pm.test(\"Error message contains email already exists\", function() {",
                  "  var jsonData = pm.response.json();",
                  "  if(jsonData.errors && jsonData.errors.length > 0) {",
                  "    pm.expect(jsonData.errors[0].message).to.include('already exists');",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
