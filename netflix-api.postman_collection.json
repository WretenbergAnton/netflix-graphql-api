        {
          "name": "Add Movie - Success",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has movie data', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.addMovie).to.exist;",
                  "    pm.expect(jsonData.data.addMovie.id).to.be.greaterThan(0);",
                  "    pm.environment.set('movie_id', jsonData.data.addMovie.id);",
                  "});",
                  "pm.test('Movie title matches input', function() {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.addMovie.title).to.equal('Test Movie');",
                  "});"
                ]
              }
            }
