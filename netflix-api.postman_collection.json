            "body": {
              "mode": "raw",
              "raw": "{\"query\":\"mutation { addMovie(title: \\\"Test Movie\\\", releaseYear: 2024, description: \\\"A test movie\\\", rating: 8.5) { id title rating createdAt } }\"}"
            },
