{
  "info": {
    "name": "Netflix GraphQL API",
    "description": "GraphQL API for Netflix movies and authentication",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation {\n  registerUser(\n    email: \"user@example.com\"\n    password: \"password123\"\n    name: \"John Doe\"\n  ) {\n    token\n    user {\n      id\n      email\n      name\n    }\n  }\n}"
              }
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation {\n  loginUser(\n    email: \"user@example.com\"\n    password: \"password123\"\n  ) {\n    token\n    user {\n      id\n      email\n      name\n    }\n  }\n}"
              }
            }
          }
        }
      ]
    },
    {
      "name": "Movies",
      "item": [
        {
          "name": "Get All Movies",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "{\n  movies(limit: 10, offset: 0) {\n    id\n    title\n    description\n    releaseYear\n    rating\n    actors {\n      name\n      character\n    }\n    genres {\n      name\n    }\n  }\n}"
              }
            }
          }
        },
        {
          "name": "Get Single Movie",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "{\n  movie(id: 1) {\n    id\n    title\n    description\n    releaseYear\n    rating\n    actors {\n      name\n      character\n    }\n  }\n}"
              }
            }
          }
        },
        {
          "name": "Search Movies",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "{\n  searchMovies(title: \"avengers\") {\n    id\n    title\n    releaseYear\n    rating\n  }\n}"
              }
            }
          }
        },
        {
          "name": "Add Movie",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation {\n  addMovie(\n    title: \"My Movie\"\n    releaseYear: 2024\n    description: \"An amazing film\"\n    rating: 8.5\n  ) {\n    id\n    title\n    releaseYear\n    rating\n  }\n}"
              }
            }
          }
        },
        {
          "name": "Update Movie",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation {\n  updateMovie(\n    id: 1\n    title: \"Updated Title\"\n    releaseYear: 2025\n    rating: 9.0\n  ) {\n    id\n    title\n    releaseYear\n    rating\n  }\n}"
              }
            }
          }
        },
        {
          "name": "Delete Movie",
          "request": {
            "method": "POST",
            "url": "{{BASE_URL}}",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation {\n  deleteMovie(id: 1)\n}"
              }
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://localhost:4000/graphql"
    },
    {
      "key": "auth_token",
      "value": ""
    }
  ]
}