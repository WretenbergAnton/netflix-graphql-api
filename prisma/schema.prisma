generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int     @id @default(autoincrement())
  email     String  @unique
  password  String
  name      String?
  movies    Movie[]
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

model Movie {
  id            Int     @id @default(autoincrement())
  showId        String  @unique @default(uuid()) @map("show_id")
  title         String
  releaseYear   Int?    @map("release_year")
  description   String?
  rating        Float?
  popularity    Float?
  voteCount     Int?    @map("vote_count")
  voteAverage   Float?  @map("vote_average")
  budget        Float?
  revenue       Float?
  dateAdded     String? @map("date_added")
  createdBy     Int     @map("created_by")
  user          User    @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  actors        Actor[]
  genres        Genre[]
  ratings       Rating[]
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("movies")
  @@index([createdBy])
}

model Actor {
  id        Int     @id @default(autoincrement())
  name      String
  character String?
  movie     Movie   @relation(fields: [movieId], references: [id], onDelete: Cascade)
  movieId   Int     @map("movie_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("actors")
  @@index([movieId])
}

model Genre {
  id        Int     @id @default(autoincrement())
  name      String
  movie     Movie   @relation(fields: [movieId], references: [id], onDelete: Cascade)
  movieId   Int     @map("movie_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("genres")
  @@index([movieId])
}

model Rating {
  id        Int     @id @default(autoincrement())
  value     Int
  comment   String?
  movie     Movie   @relation(fields: [movieId], references: [id], onDelete: Cascade)
  movieId   Int     @map("movie_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("ratings")
  @@index([movieId])
}
