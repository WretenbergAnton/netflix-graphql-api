{
  "name": "netflix-graphql-api",
  "version": "1.0.0",
  "description": "Netflix GraphQL API with authentication",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "seed": "node prisma/seed.js",
    "lint": "eslint src/ server.js",
    "lint:fix": "eslint src/ server.js --fix",
    "test": "newman run netflix-api.postman_collection.json --environment netflix-api.postman_environment.json --reporters cli,json"
  },
  "dependencies": {
    "@apollo/server": "^4.10.0",
    "@prisma/client": "^6.19.2",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.6",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "graphql": "^16.8.1",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.11.3",
    "prisma": "^6.19.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "newman": "^6.1.0",
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": "20.x"
  }
}
